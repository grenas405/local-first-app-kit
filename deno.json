{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env backend/server.ts",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env backend/server.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env backend/",
    "build:backend": "deno compile --no-terminal --no-npm --allow-net --allow-read --allow-write --allow-env --output dist/app-backend.exe --target x86_64-pc-windows-msvc backend/server.ts",
    "build:backend:local": "deno compile --no-npm --allow-net --allow-read --allow-write --allow-env --output dist/app-backend backend/server.ts",
    "docs:check": "node scripts/validate-docs.mjs && node scripts/gen-adrs.mjs --check",
    "domain:apply": "node scripts/apply-domain.mjs",
    "verify:generated": "node scripts/apply-domain.mjs && git diff --exit-code -- backend/seed.generated.ts backend/logo.ts renderer/src/catalog-meta.ts renderer/src/brand.generated.css renderer/src/assets/active-logo.svg"
  },
  "nodeModulesDir": "none",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "hono": "jsr:@hono/hono@^4.6.14"
  },
  "fmt": {
    "include": ["backend/"]
  },
  "lint": {
    "include": ["backend/"]
  }
}
